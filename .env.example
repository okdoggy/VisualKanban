# PostgreSQL connection string (MIT-licensed pg client)
DATABASE_URL=postgresql://visualkanban:visualkanban@localhost:5432/visualkanban

# Optional: TLS mode for managed PostgreSQL (disable | require)
PGSSLMODE=disable
# Optional: set false only if your CA chain is handled elsewhere
PGSSL_REJECT_UNAUTHORIZED=true

# Client/Server shared-state sync controls
VK_STATE_SYNC_ENABLED=true
VK_STATE_SYNC_POLL_INTERVAL_MS=5000
NEXT_PUBLIC_VK_STATE_SYNC_ENABLED=true
NEXT_PUBLIC_VK_STATE_SYNC_POLL_INTERVAL_MS=5000
NEXT_PUBLIC_VK_STATE_WORKSPACE_ID=main
